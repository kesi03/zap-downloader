    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "inquirer": "^13.3.2",
    "inquirer-fuzzy-path": "^2.3.0",
    "js-yaml": "^4.1.1",
    "p-limit": "^7.3.0",
    "xml2js": "^0.6.2",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/xml2js": "^0.4.14",
    "@types/yargs": "^17.0.35",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
