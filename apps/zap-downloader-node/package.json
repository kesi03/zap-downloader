{
  "name": "@mockholm/zap-downloader",
  "version": "1.0.0",
  "description": "CLI tool to download OWASP ZAP and addons",
  "main": "dist/index.js",
  "bin": {
    "zap-downloader": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "list": "ts-node src/index.ts list",
    "info": "ts-node src/index.ts info",
    "core": "ts-node src/index.ts core",
    "addons": "ts-node src/index.ts addons",
    "create-config": "ts-node src/index.ts create-config",
    "create-zap-config": "ts-node src/index.ts create-zap-config",
    "download-zap": "ts-node src/index.ts download-zap",
    "package": "ts-node src/index.ts package",
    "workspace": "ts-node src/index.ts workspace"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kesi03/zap-downloader.git"
