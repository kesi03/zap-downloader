{
  "name": "zap-downloader-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "offline:pack": "pnpm --filter zap-downloader-node offline:pack",
    "offline:unpack": "pnpm --filter zap-downloader-node offline:unpack",
    "dependencies:chrome": "pnpm --filter zap-downloader-node dependencies:chrome",
    "dependencies:firefox": "pnpm --filter zap-downloader-node dependencies:firefox",
    "verify:chrome": "pnpm --filter browser-verification verify:chrome",
    "verify:firefox": "pnpm --filter browser-verification verify:firefox"
  },
  "devDependencies": {
    "@mockholm/zap-downloader": "workspace:*",
    "browser-verification": "workspace:*",
    "ts-node": "^10.9.2"
  }
}
